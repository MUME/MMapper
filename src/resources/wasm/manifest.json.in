{
  "name": "MUME Mapper",
  "short_name": "MMapper",
  "description": "MMapper is a graphical mapping tool that enhances the MUME (Multi-Users in Middle Earth) game experience.",
  "start_url": "./",
  "display": "standalone",
  "background_color": "@MMAPPER_THEME_COLOR@",
  "theme_color": "@MMAPPER_THEME_COLOR@",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ]
}
